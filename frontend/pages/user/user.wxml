<view class="container">
  <!-- 渐变头部 -->
  <view class="page-header page-header-blue">
    <view class="page-header-top">
      <text class="page-title">我的</text>
    </view>
    <!-- 用户信息玻璃卡片 -->
    <view class="profile-glass">
      <view class="profile-left">
        <view class="avatar-wrap">
          <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="level-badge">{{userInfo.level}}</view>
        </view>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{userInfo.nickname || userInfo.username}}</text>
        <view class="profile-streak">
          <text>🔥</text>
          <text class="streak-text">已学习 {{userInfo.createdDays}} 天</text>
        </view>
      </view>
    </view>
    <!-- 进度条 -->
    <view class="progress-bar-wrap">
      <view class="progress-bar" style="width: {{progress.percent}}%"></view>
    </view>
    <view class="progress-stats">
      <text class="progress-label">单词掌握进度</text>
      <text class="progress-count">{{progress.mastered}}/{{progress.total}}</text>
    </view>
    <view class="page-header-wave">
      <text style="font-size:80rpx;color:rgba(255,255,255,0.12);letter-spacing:-4rpx">~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~</text>
    </view>
  </view>

  <!-- 积分卡片 -->
  <view class="points-card">
    <view class="points-bg"></view>
    <view class="points-content">
      <view class="points-left">
        <text class="points-label">我的积分</text>
        <view class="points-value">
          <text class="points-coin">⭐</text>
          <text class="points-number">{{pointsBalance.balance}}</text>
        </view>
        <view class="points-meta">
          <text>累计获得 {{pointsBalance.totalEarned}}</text>
          <text class="points-divider">|</text>
          <text>累计消费 {{pointsBalance.totalSpent}}</text>
        </view>
      </view>
      <view class="points-right">
        <view class="checkin-btn {{checkinInfo.checkedIn ? 'checked-in' : ''}}" bindtap="checkin">
          <text class="checkin-icon">{{checkinInfo.checkedIn ? '✅' : '📅'}}</text>
          <text class="checkin-text">{{checkinInfo.checkedIn ? '已签到' : '签到'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 统计网格 -->
  <view class="stats-grid">
    <view wx:for="{{stats}}" wx:key="label" class="stat-card">
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-section">
    <view
      wx:for="{{menuItems}}"
      wx:key="label"
      class="menu-item"
      bindtap="goToMenuItem"
      data-item="{{item}}"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <view class="menu-content">
        <text class="menu-label">{{item.label}}</text>
      </view>
      <text wx:if="{{item.badge}}" class="menu-badge">{{item.badge}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" bindtap="logout">
    <text class="logout-text">退出登录</text>
  </view>
</view>
