.container {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ===== 头部 ===== */
.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 36rpx;
  color: #fff;
  flex-shrink: 0;
}

.header-info {
  flex: 1;
  margin: 0 20rpx;
}

.book-name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.word-count {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.batch-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #fff;
  flex-shrink: 0;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  margin: -16rpx 20rpx 20rpx;
  padding: 18rpx 28rpx;
  border-radius: 50rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  z-index: 5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
  color: var(--text-muted);
}

/* ===== 单词列表 ===== */
.word-list {
  padding: 0 20rpx 160rpx;
  height: calc(100vh - 260rpx);
}

.word-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s, box-shadow 0.2s;
  animation: fadeInUp 0.3s var(--ease-out);
}

.word-item:active {
  box-shadow: var(--shadow-md);
}

.word-item.batch-mode {
  padding-left: 16rpx;
}

.word-checkbox-wrapper {
  display: inline-flex;
  align-items: center;
  margin-right: 16rpx;
  padding-top: 8rpx;
}

.word-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  transition: all 0.2s;
}

.word-checkbox.checked {
  background: var(--purple);
  border-color: var(--purple);
  transform: scale(1.1);
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.word-main-content {
  flex: 1;
  min-width: 0;
}

.word-header {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.phonetic {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 14rpx;
}

.word-body {
  margin-top: 10rpx;
}

.word-definition {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.word-part {
  font-size: 22rpx;
  color: var(--purple);
  margin-top: 6rpx;
  display: inline-block;
  background: rgba(102, 126, 234, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

/* 单词操作 */
.word-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.9);
}

.action-btn.edit {
  background: rgba(102, 126, 234, 0.1);
  color: var(--purple);
}

.action-btn.delete {
  background: rgba(245, 87, 108, 0.1);
  color: var(--red);
}

/* ===== FAB ===== */
.fab-btn {
  position: fixed;
  right: 30rpx;
  bottom: calc(var(--safe-bottom) + 30rpx);
  width: 112rpx;
  height: 112rpx;
  background: var(--purple-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  z-index: 100;
  transition: transform 0.2s var(--ease-out);
  animation: fabEnter 0.5s var(--ease-bounce);
}

.fab-btn:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
}

/* ===== 批量操作栏 ===== */
.batch-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + var(--safe-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  animation: slideUp 0.3s var(--ease-out);
}

.select-all-btn {
  padding: 18rpx 32rpx;
  background: var(--bg-page);
  border-radius: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.select-all-btn text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.delete-selected-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, var(--red) 0%, #f65a78 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(245, 87, 108, 0.35);
}

.delete-selected-btn.disabled {
  background: #d8d8d8;
  box-shadow: none;
}

.delete-selected-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 单词详情 ===== */
.detail-word-section {
  text-align: center;
  padding: 20rpx 0;
}

.detail-word {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.detail-phonetic {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  display: block;
}

.detail-part {
  font-size: 24rpx;
  color: var(--purple);
  margin-top: 8rpx;
  display: inline-block;
  background: rgba(102, 126, 234, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.detail-divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

.detail-meaning-section {
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 10rpx;
  display: block;
}

.detail-definition {
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.detail-example-box {
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 20rpx;
}

.detail-example {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  display: block;
}

.detail-example-trans {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

/* ===== 弹窗附加样式 ===== */
.input-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.ai-fill-btn {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  height: 88rpx;
  background: var(--purple-gradient);
  border-radius: 0 16rpx 16rpx 0;
  flex-shrink: 0;
}

.ai-fill-btn:active {
  opacity: 0.85;
}

.ai-icon {
  font-size: 30rpx;
  margin-right: 6rpx;
}

.ai-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

/* ===== 单词详情操作区 ===== */
.detail-actions {
  margin: 24rpx 0;
  display: flex;
  gap: 16rpx;
}

.detail-action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: var(--radius-md);
  background: var(--bg-page);
  text-align: center;
  border: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-action-btn:active {
  opacity: 0.7;
}

.detail-action-btn.mastered {
  background: rgba(103, 194, 58, 0.1);
  border-color: rgba(103, 194, 58, 0.3);
  color: #67c23a;
}

/* ===== 笔记区 ===== */
.detail-note-section {
  margin: 20rpx 0;
}

.detail-note-box {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.note-input {
  flex: 1;
  min-height: 80rpx;
  padding: 16rpx 20rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  border: 1rpx solid var(--border);
}

.note-save-btn {
  padding: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  background: #d8d8d8;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #fff;
  text-align: center;
}

.note-save-btn.active {
  background: var(--purple-gradient);
}

.note-save-btn:active {
  opacity: 0.85;
}

.detail-note-display {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #fdf6ec;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  margin-top: 12rpx;
  display: block;
  line-height: 1.6;
}
