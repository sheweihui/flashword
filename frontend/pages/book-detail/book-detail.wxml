<view class="container">
  <!-- 渐变头部 -->
  <view class="page-header page-header-purple">
    <view class="page-header-top">
      <view class="header-back" bindtap="goBack">
        <text>←</text>
      </view>
      <view class="header-info">
        <text class="book-name">{{ bookName }}</text>
        <text class="word-count">{{ filteredWords.length }} 个单词</text>
      </view>
      <view class="batch-btn" bindtap="toggleBatchMode">
        <text>{{ batchMode ? '取消' : '批量' }}</text>
      </view>
    </view>
    <view class="page-header-wave">
      <text style="font-size:80rpx;color:rgba(255,255,255,0.12);letter-spacing:-4rpx">~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索单词..." value="{{ searchKeyword }}" bindinput="onSearchInput" />
  </view>

  <!-- 单词列表 -->
  <scroll-view class="word-list" scroll-y>
    <view wx:if="{{loading}}" class="empty-state">
      <text class="empty-icon">📖</text>
      <text class="empty-title">加载中...</text>
    </view>

    <view wx:elif="{{filteredWords.length === 0}}" class="empty-state">
      <text class="empty-icon">📚</text>
      <text class="empty-title">{{ searchKeyword ? '未找到匹配的单词' : '单词书还没有单词' }}</text>
      <text class="empty-desc">点击右下角 + 添加单词</text>
    </view>

    <view class="word-item {{ batchMode ? 'batch-mode' : '' }}" wx:for="{{ filteredWords }}" wx:key="id" wx:for-index="idx">
      <view class="word-checkbox-wrapper" wx:if="{{ batchMode }}" bindtap="toggleWordSelection" data-word="{{ item }}">
        <view class="word-checkbox {{selectedWords[item.id || item.wordText] ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{selectedWords[item.id || item.wordText]}}">✓</text>
        </view>
      </view>
      <view class="word-main-content" bindtap="{{ batchMode ? '' : 'showWordDetail' }}" data-word="{{ item }}">
        <view class="word-header">
          <text class="word-text">{{ item.wordText }}</text>
          <text class="phonetic">{{ item.phonetic }}</text>
        </view>
        <view class="word-body">
          <text class="word-definition">{{ item.definition }}</text>
          <text class="word-part">{{ item.partOfSpeech }}</text>
        </view>
      </view>
      <view class="word-actions" wx:if="{{ !batchMode }}">
        <view class="action-btn edit" catchtap="showEditWordModal" data-word="{{ item }}">✎</view>
        <view class="action-btn delete" catchtap="deleteWord" data-word="{{ item }}">✕</view>
      </view>
    </view>
  </scroll-view>

  <!-- FAB -->
  <view class="fab-btn" bindtap="showAddWordModal" wx:if="{{ !batchMode }}">
    <view class="fab-glow"></view>
    <text class="fab-icon">+</text>
  </view>

  <!-- 批量操作栏 -->
  <view class="batch-action-bar" wx:if="{{ batchMode }}">
    <view class="select-all-btn" bindtap="toggleSelectAll">
      <text>{{ selectedCount === filteredWords.length && filteredWords.length > 0 ? '取消全选' : '全选' }}</text>
    </view>
    <view class="delete-selected-btn {{ selectedCount === 0 ? 'disabled' : '' }}" bindtap="batchDeleteWords">
      <text>删除选中 ({{ selectedCount }})</text>
    </view>
  </view>

  <!-- 添加单词弹窗 -->
  <view class="modal-overlay" wx:if="{{ showModal }}" bindtap="closeModal">
    <view class="modal-content" catchtap>
      <view class="modal-handle"></view>
      <view class="modal-header">
        <text class="modal-title">添加单词</text>
        <view class="modal-close" catchtap="closeModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="form-item">
          <text class="form-label">单词 <text class="required">*</text></text>
          <view class="input-row">
            <input class="form-input" style="flex:1;border-radius:16rpx 0 0 16rpx" placeholder="请输入单词" value="{{ wordForm.wordText }}" bindinput="handleInput" data-field="wordText" />
            <view class="ai-fill-btn" bindtap="aiFillWord">
              <text class="ai-icon">🤖</text>
              <text class="ai-text">AI代填</text>
            </view>
          </view>
        </view>
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">音标</text>
            <input class="form-input" placeholder="音标" value="{{ wordForm.phonetic }}" bindinput="handleInput" data-field="phonetic" />
          </view>
          <view class="form-item half">
            <text class="form-label">词性</text>
            <input class="form-input" placeholder="词性" value="{{ wordForm.partOfSpeech }}" bindinput="handleInput" data-field="partOfSpeech" />
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">释义 <text class="required">*</text></text>
          <textarea class="form-textarea" placeholder="请输入中文释义" value="{{ wordForm.definition }}" bindinput="handleInput" data-field="definition" />
        </view>
        <view class="form-item">
          <text class="form-label">例句</text>
          <textarea class="form-textarea" placeholder="请输入例句" value="{{ wordForm.exampleSentence }}" bindinput="handleInput" data-field="exampleSentence" />
        </view>
        <view class="form-item">
          <text class="form-label">例句翻译</text>
          <textarea class="form-textarea" placeholder="请输入例句翻译" value="{{ wordForm.exampleTranslation }}" bindinput="handleInput" data-field="exampleTranslation" />
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="btn btn-ghost btn-block" catchtap="closeModal">取消</view>
        <view class="btn btn-purple btn-block" bindtap="submitAddWord">添加</view>
      </view>
    </view>
  </view>

  <!-- 单词详情弹窗（底部弹出） -->
  <view class="modal-overlay" wx:if="{{ showWordDetail }}" bindtap="closeWordDetail">
    <view class="modal-content" catchtap>
      <view class="modal-handle"></view>
      <view class="modal-header">
        <text class="modal-title">单词详情</text>
        <view class="modal-close" catchtap="closeWordDetail">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="detail-word-section">
          <text class="detail-word">{{ selectedWord.wordText }}</text>
          <text class="detail-phonetic">{{ selectedWord.phonetic }}</text>
          <text class="detail-part">{{ selectedWord.partOfSpeech }}</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-meaning-section">
          <text class="detail-label">释义</text>
          <text class="detail-definition">{{ selectedWord.definition }}</text>
        </view>
        <view class="detail-example-section" wx:if="{{ selectedWord.exampleSentence }}">
          <text class="detail-label">例句</text>
          <view class="detail-example-box">
            <text class="detail-example">{{ selectedWord.exampleSentence }}</text>
            <text class="detail-example-trans">{{ selectedWord.exampleTranslation }}</text>
          </view>
        </view>

        <!-- 操作区 -->
        <view class="detail-actions">
          <view class="detail-action-btn {{ selectedWord.mastered ? 'mastered' : '' }}" bindtap="markAsMastered">
            <text>{{ selectedWord.mastered ? '✅ 已掌握' : '○ 标记已掌握' }}</text>
          </view>
        </view>

        <!-- 笔记 -->
        <view class="detail-note-section">
          <text class="detail-label">笔记</text>
          <view class="detail-note-box">
            <textarea class="note-input" placeholder="添加笔记..." value="{{ noteText }}" bindinput="onNoteInput" maxlength="500" />
            <view class="note-save-btn {{ noteText ? 'active' : '' }}" bindtap="saveNote">
              <text>保存</text>
            </view>
          </view>
          <text class="detail-note-display" wx:if="{{ selectedWord.note }}">
            {{ selectedWord.note }}
          </text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 编辑单词弹窗 -->
  <view class="modal-overlay" wx:if="{{ showEditModal }}" bindtap="closeEditModal">
    <view class="modal-content" catchtap>
      <view class="modal-handle"></view>
      <view class="modal-header">
        <text class="modal-title">修改单词</text>
        <view class="modal-close" catchtap="closeEditModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="form-item">
          <text class="form-label">单词 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入单词" value="{{ editForm.wordText }}" bindinput="handleEditInput" data-field="wordText" />
        </view>
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">音标</text>
            <input class="form-input" placeholder="音标" value="{{ editForm.phonetic }}" bindinput="handleEditInput" data-field="phonetic" />
          </view>
          <view class="form-item half">
            <text class="form-label">词性</text>
            <input class="form-input" placeholder="词性" value="{{ editForm.partOfSpeech }}" bindinput="handleEditInput" data-field="partOfSpeech" />
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">释义 <text class="required">*</text></text>
          <textarea class="form-textarea" placeholder="请输入中文释义" value="{{ editForm.definition }}" bindinput="handleEditInput" data-field="definition" />
        </view>
        <view class="form-item">
          <text class="form-label">例句</text>
          <textarea class="form-textarea" placeholder="请输入例句" value="{{ editForm.exampleSentence }}" bindinput="handleEditInput" data-field="exampleSentence" />
        </view>
        <view class="form-item">
          <text class="form-label">例句翻译</text>
          <textarea class="form-textarea" placeholder="请输入例句翻译" value="{{ editForm.exampleTranslation }}" bindinput="handleEditInput" data-field="exampleTranslation" />
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="btn btn-ghost btn-block" catchtap="closeEditModal">取消</view>
        <view class="btn btn-purple btn-block" bindtap="submitEditWord">保存</view>
      </view>
    </view>
  </view>
</view>
