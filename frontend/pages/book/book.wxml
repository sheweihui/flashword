<view class="container">
  <!-- 渐变头部 -->
  <view class="page-header page-header-green">
    <view class="page-header-top">
      <text class="page-title">我的单词书</text>
      <view class="header-action" bindtap="showAddWordModal">
        <text>+ 添加单词</text>
      </view>
    </view>
    <text class="page-subtitle">共 {{books.length}} 本单词书</text>
    <view class="page-header-wave">
      <text style="font-size:80rpx;color:rgba(255,255,255,0.12);letter-spacing:-4rpx">~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~</text>
    </view>
  </view>

  <!-- 单词书列表 -->
  <view class="book-list">
    <view wx:if="{{!isLoading && books.length === 0}}" class="empty-state">
      <text class="empty-icon">📚</text>
      <text class="empty-title">暂无单词书</text>
      <text class="empty-desc">点击右下角的 + 按钮创建你的第一本单词书</text>
    </view>

    <view
      wx:for="{{books}}"
      wx:key="id"
      class="book-card"
      bindtap="goToBookDetail"
      data-book="{{item}}"
    >
      <view class="book-cover {{'color-' + (index % 5)}}">
        <text class="cover-letter">{{item.bookName.charAt(0).toUpperCase()}}</text>
      </view>
      <view class="book-info">
        <text class="book-name">{{item.bookName}}</text>
        <text class="book-desc">{{item.description || '暂无描述'}}</text>
        <view class="book-meta">
          <text class="word-count">📖 {{item.wordCount}} 词</text>
          <text class="create-time">{{formatDate(item.createdAt)}}</text>
        </view>
      </view>
      <view class="book-actions">
        <view class="action-btn edit" catchtap="editBookTap" data-bookid="{{item.id}}" data-bookname="{{item.bookName}}" data-desc="{{item.description || ''}}">
          <text>✎</text>
        </view>
        <view class="action-btn delete" catchtap="deleteBookTap" data-bookid="{{item.id}}" data-bookname="{{item.bookName}}">
          <text>✕</text>
        </view>
      </view>
    </view>
  </view>

  <!-- FAB 按钮 -->
  <view class="fab-btn" bindtap="showCreateBookModal">
    <view class="fab-glow"></view>
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加单词弹窗 -->
  <view class="modal-overlay" wx:if="{{showAddModal}}" bindtap="closeAddModal">
    <view class="modal-content" catchtap>
      <view class="modal-handle"></view>
      <view class="modal-header">
        <text class="modal-title">添加单词</text>
        <view class="modal-close" catchtap="closeAddModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="form-item">
          <text class="form-label">选择单词书 <text class="required">*</text></text>
          <view class="book-options">
            <view
              wx:for="{{books}}"
              wx:key="id"
              class="book-option {{selectedBookId === item.id ? 'selected' : ''}}"
              bindtap="selectBook"
              data-book-id="{{item.id}}"
            >{{item.bookName}}</view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">单词 <text class="required">*</text></text>
          <view class="input-row">
            <input class="form-input" style="flex:1;border-radius:16rpx 0 0 16rpx" placeholder="请输入单词" value="{{wordForm.wordText}}" bindinput="handleInput" data-field="wordText" />
            <view class="ai-fill-btn" bindtap="aiFillWord">
              <text class="ai-icon">🤖</text>
              <text class="ai-text">AI代填</text>
            </view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">音标</text>
          <input class="form-input" placeholder="请输入音标" value="{{wordForm.phonetic}}" bindinput="handleInput" data-field="phonetic" />
        </view>
        <view class="form-item">
          <text class="form-label">词性</text>
          <input class="form-input" placeholder="如：n. v. adj." value="{{wordForm.partOfSpeech}}" bindinput="handleInput" data-field="partOfSpeech" />
        </view>
        <view class="form-item">
          <text class="form-label">中文释义 <text class="required">*</text></text>
          <input class="form-input" placeholder="请输入中文释义" value="{{wordForm.definition}}" bindinput="handleInput" data-field="definition" />
        </view>
        <view class="form-item">
          <text class="form-label">例句</text>
          <textarea class="form-textarea" placeholder="请输入例句" value="{{wordForm.exampleSentence}}" bindinput="handleInput" data-field="exampleSentence" />
        </view>
        <view class="form-item">
          <text class="form-label">例句翻译</text>
          <textarea class="form-textarea" placeholder="请输入例句翻译" value="{{wordForm.exampleTranslation}}" bindinput="handleInput" data-field="exampleTranslation" />
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="btn btn-ghost btn-block" catchtap="closeAddModal">取消</view>
        <view class="btn btn-success btn-block" bindtap="submitAddWord">添加</view>
      </view>
    </view>
  </view>

  <!-- 创建单词书弹窗 -->
  <view class="modal-overlay" wx:if="{{showCreateBookModal}}" bindtap="closeCreateBookModal">
    <view class="modal-content" catchtap>
      <view class="modal-handle"></view>
      <view class="modal-header">
        <text class="modal-title">创建单词书</text>
        <view class="modal-close" catchtap="closeCreateBookModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="form-item">
          <text class="form-label">名称 <text class="required">*</text></text>
          <input class="form-input" placeholder="给你的单词书起个名字" value="{{newBookName}}" bindinput="onBookNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">描述</text>
          <textarea class="form-textarea" placeholder="简单描述一下（可选）" value="{{newBookDesc}}" bindinput="onBookDescInput" />
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="btn btn-ghost btn-block" catchtap="closeCreateBookModal">取消</view>
        <view class="btn btn-success btn-block" bindtap="createBook">创建</view>
      </view>
    </view>
  </view>

  <!-- 编辑单词书弹窗 -->
  <view class="modal-overlay" wx:if="{{showEditBookModal}}" bindtap="closeEditModal">
    <view class="modal-content" catchtap>
      <view class="modal-handle"></view>
      <view class="modal-header">
        <text class="modal-title">修改单词书</text>
        <view class="modal-close" catchtap="closeEditModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="form-item">
          <text class="form-label">名称 <text class="required">*</text></text>
          <input class="form-input" placeholder="输入新名称" value="{{editBookName}}" bindinput="editNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">描述</text>
          <textarea class="form-textarea" placeholder="输入新描述" value="{{editBookDesc}}" bindinput="editDescInput" />
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="btn btn-ghost btn-block" catchtap="closeEditModal">取消</view>
        <view class="btn btn-success btn-block" bindtap="confirmEditBook">保存</view>
      </view>
    </view>
  </view>
</view>
