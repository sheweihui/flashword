page {
  background-color: var(--bg-page);
}

.container {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(var(--safe-bottom) + 120rpx);
}

/* ===== 单词书列表 ===== */
.book-list {
  padding: 24rpx;
}

/* ===== 单词书卡片 ===== */
.book-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
  animation: fadeInUp 0.4s var(--ease-out);
}

.book-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

/* 装饰封面 */
.book-cover {
  width: 100rpx;
  height: 110rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.book-cover.color-0 { background: linear-gradient(135deg, #667eea, #764ba2); }
.book-cover.color-1 { background: linear-gradient(135deg, #5eb97d, #7ed39e); }
.book-cover.color-2 { background: linear-gradient(135deg, #f093fb, #f5576c); }
.book-cover.color-3 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.book-cover.color-4 { background: linear-gradient(135deg, #fa709a, #fee140); }

.cover-letter {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 书本信息 */
.book-info {
  flex: 1;
  min-width: 0;
}

.book-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.book-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.book-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.word-count {
  font-size: 24rpx;
  color: var(--green);
}

.create-time {
  font-size: 22rpx;
  color: #ccc;
}

/* 操作按钮 */
.book-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
}

.action-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border-radius: 50%;
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.9);
}

.action-btn.edit {
  background: rgba(102, 126, 234, 0.1);
  color: var(--purple);
}

.action-btn.delete {
  background: rgba(245, 87, 108, 0.1);
  color: var(--red);
}

/* ===== 弹窗表单额外样式 ===== */
.input-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.ai-fill-btn {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 88rpx;
  background: var(--purple-gradient);
  border-radius: 0 16rpx 16rpx 0;
  flex-shrink: 0;
}

.ai-fill-btn:active {
  opacity: 0.85;
}

.ai-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.ai-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.book-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.book-option {
  padding: 14rpx 28rpx;
  background: var(--bg-page);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.book-option:active {
  transform: scale(0.96);
}

.book-option.selected {
  background: var(--green-gradient);
  color: #fff;
}
