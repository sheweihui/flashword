.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 30%, #6ba3e0 70%, #4a90d9 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  animation: gradientShift 8s ease infinite;
  background-size: 200% 200%;
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ===== 装饰形状 ===== */
.bg-shapes {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.shape {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
}

.shape-1 {
  width: 600rpx;
  height: 600rpx;
  background: #fff;
  top: -200rpx;
  right: -100rpx;
  animation: float 6s ease-in-out infinite;
}

.shape-2 {
  width: 400rpx;
  height: 400rpx;
  background: #fff;
  bottom: 10%;
  left: -100rpx;
  animation: float 8s ease-in-out infinite reverse;
}

.shape-3 {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  bottom: 30%;
  right: 20%;
  animation: float 5s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-30rpx) rotate(10deg); }
}

/* ===== Logo ===== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
  animation: fadeInUp 0.6s var(--ease-out);
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(20px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.15);
}

.logo-emoji {
  font-size: 72rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== 磨砂玻璃表单卡片 ===== */
.form-card {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.92) !important;
  animation: fadeInUp 0.6s var(--ease-out);
  animation-delay: 0.1s;
}

.tab-bar {
  display: flex;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-item text {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tab-item.active text {
  color: var(--primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.form-content {
  padding: 40rpx;
}

.input-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
  margin-bottom: 10rpx;
  transition: border-color 0.2s;
}

.input-item:focus-within {
  border-bottom-color: var(--primary);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 32rpx;
  color: var(--text-primary);
}

.toggle-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

/* 输入框占位符颜色 */
.input-placeholder {
  color: var(--text-muted);
  font-weight: 400;
}

/* ===== 按钮 ===== */
.btn-disabled {
  opacity: 0.6;
}

/* ===== 页脚 ===== */
.footer {
  margin-top: auto;
  text-align: center;
  padding: 40rpx 0;
  position: relative;
  z-index: 1;
}

.footer text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}
